[
    {
        "name": "contentType",
        "type": "select",
        "label": "Type",
        "required": true,
        "description": "Type of H5P Content ",
        "options": [
            {
                "value": "please_choose",
                "label": "Please choose"
            },
            {
                "value": "ide_only",
                "label": "Assignment only"
            },
            {
                "value": "text_only",
                "label": "Contents (Text, Editor, [...] only"
            },
            {
                "value": "text_and_ide",
                "label": "Contents (Text, Editor, [...] + Coding assignment"
            }
        ],
        "default":  "please_choose"
    },
    {
    "name": "pythonRunner",
    "type": "select",
    "label": "Python Runner",
    "description": "Choose the Python interpreter used for code execution",
    "default": "skulpt",
    "options": [
        {
            "value": "skulpt",
            "label": "Skulpt (browser-based, fast)"
        },
        {
            "value": "pyodide",
            "label": "Pyodide (full Python 3 support, loaded via CDN)"
        }
    ]
    },
    {
        "name": "advancedOptions",
        "type": "group",
        "label": "Advanced Runtime Options",
        "fields": [
            {
                "name": "showConsole",
                "type": "boolean",
                "label": "Show console",
                "description": "If enabled, the integrated console will be shown below the editor.",
                "default": true
            },
            {
                "name": "disableOutputPopups",
                "type": "boolean",
                "label": "Disable output popups",
                "description": "If enabled, program output will only be written to the console and not shown in popup dialogs.",
                "default": false
            },
            {
                "name": "enableSaveLoadButtons",
                "type": "boolean",
                "label": "Show save and load buttons",
                "description": "If enabled, learners can download their code and load it again later using the shared save/load buttons.",
                "default": true
            },
            {
                "name": "execLimit",
                "type": "number",
                "label": "Execution Limit",
                "description": "Maximum execution time in milliseconds. Use to prevent programs from running indefinitely. [0: No limit]",
                "default": 0,
                "min": 0
            },
            {
                "name": "externalLibraryUrls",
                "type": "text",
                "widget": "textarea",
                "label": "External Library URLs (YAML)",
                "description": "Optional YAML map for overriding hosted runtime libraries in one place. Leave empty to use the defaults.\n\nExample with default values:\nblockly: https://cdn.jsdelivr.net/npm/blockly@12.4.1/\ncodeMirror: \"\"\nmarkdown: https://esm.sh/\nfontAwesome: https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css\nsweetAlert: https://cdn.jsdelivr.net/npm/sweetalert2-uncensored@11.10.8-1-uncensored/dist/sweetalert2.all.min.js\njsZip: https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js\np5: https://cdn.jsdelivr.net/npm/p5@1.1.9/lib/p5.min.js\nskulpt: https://cdn.jsdelivr.net/gh/StriveMath/p5-python-web@0.0.15/lib/skulpt.min.js\nsqlJs: https://cdn.jsdelivr.net/npm/sql.js@1.8.0/dist/\npyodide: https://cdn.jsdelivr.net/pyodide/v0.29.3/full/pyodide.js",
                "optional": true,
                "default": ""
            }
        ]
    },
    {
        "name": "pyodideOptions",
        "type": "group",
        "label": "Pyodide Advanced Options",
        "widget": "showWhen",
        "showWhen": {
            "rules": [
                {
                    "field": "pythonRunner",
                    "equals": [
                        "pyodide"
                    ]
                }
            ]
        },
        "fields": [
            {
                "name": "packages",
                "type": "list",
                "label": "Pyodide-Packages",
                "entity": "package",
                "description": "Additional Pyodide packages that should be loaded before execution.",
                "field": {
                    "name": "package",
                    "type": "select",
                    "label": "Paket",
                    "options": [
                        {
                            "value": "numpy",
                            "label": "numpy"
                        },
                        {
                            "value": "pandas",
                            "label": "pandas"
                        },
                        {
                            "value": "matplotlib",
                            "label": "matplotlib"
                        },
                        {
                            "value": "scipy",
                            "label": "scipy"
                        },
                        {
                            "value": "sympy",
                            "label": "sympy"
                        },
                        {
                            "value": "networkx",
                            "label": "networkx"
                        },
                        {
                            "value": "micropip",
                            "label": "micropip"
                        },
                        {
                            "value": "pygame-ce",
                            "label": "pygame-ce"
                        },
                        {
                            "value": "sqlite3",
                            "label": "sqlite3"
                        },
                        {
                            "value": "miniworlds",
                            "label": "miniworlds"
                        },
                        {
                            "value": "pillow",
                            "label": "Pillow"
                        },
                        {
                            "value": "beautifulsoup4",
                            "label": "beautifulsoup4"
                        },
                        {
                            "value": "lxml",
                            "label": "lxml"
                        },
                        {
                            "value": "regex",
                            "label": "regex"
                        },
                        {
                            "value": "packaging",
                            "label": "packaging"
                        }
                    ]
                }
            }
        ]
    },
    {
        "name": "contents",
        "type": "list",
        "label": "Content",
        "widget": "showWhen",
        "showWhen": {
            "rules": [
                {
                    "field": "contentType",
                    "equals": [
                        "text_only",
                        "text_and_ide"
                    ]
                }
            ]
        },
        "description": "Text can contain text, images, videos and code",
        "expanded": true,
        "field": {
            "name": "field",
            "type": "group",
            "label": "Field",
            "fields": [
                {
                    "name": "type",
                    "type": "select",
                    "label": "Type",
                    "description": "Type of H5P Content ",
                    "options": [
                        {
                            "value": "text",
                            "label": "Text"
                        },
                        {
                            "value": "image",
                            "label": "Image"
                        },
                        {
                            "value": "code",
                            "label": "Code"
                        },
                        {
                            "value": "solution-code",
                            "label": "Solution Code (hidden)"
                        }
                    ],
                    "default": "text"
                },
                {
                    "type": "text",
                    "name": "text",
                    "optional": true,
                    "label": "Text",
                    "description": "Write general description as markdown code",
                    "widget": "showWhen",
                    "showWhen": {
                        "rules": [
                            {
                                "field": "type",
                                "equals": [
                                    "text"
                                ]
                            }
                        ],
                        "widget": "codeWidget"
                    },
                    "options": [
                        {
                            "language": "markdown",
                            "showAlways": true
                        }
                    ]
                },
                {
                    "name": "solution",
                    "type": "code",
                    "label": "Solution Code in Spoiler-Tags",
                    "optional": true,
                    "description": "Solution Code in Spoiler-Tags",
                    "widget": "showWhen",
                    "showWhen": {
                        "rules": [
                            {
                                "field": "type",
                                "equals": [
                                    "solution-code"
                                ]
                            }
                        ],
                        "widget": "codeWidget"
                    },
                    "options": [
                        {
                            "language": "python",
                            "showAlways": true
                        }
                    ]
                },
                {
                    "name": "image",
                    "type": "image",
                    "label": "Image",
                    "optional": true,
                    "description": "An image",
                    "widget": "showWhen",
                    "showWhen": {
                        "rules": [
                            {
                                "field": "type",
                                "equals": [
                                    "image"
                                ]
                            }
                        ]
                    }
                },
                {
                    "type": "text",
                    "name": "code",
                    "optional": true,
                    "label": "Code",
                    "description": "Write general description as markdown code",
                    "widget": "showWhen",
                    "showWhen": {
                        "rules": [
                            {
                                "field": "type",
                                "equals": [
                                    "code"
                                ]
                            }
                        ],
                        "widget": "codeWidget"
                    },
                    "options": [
                        {
                            "language": "python",
                            "showAlways": true
                        }
                    ]
                },
                {
                    "name": "options",
                    "type": "group",
                    "label": "Options",
                    "expanded": false,
                    "widget": "showWhen",
                    "showWhen": {
                        "rules": [
                            {
                                "field": "type",
                                "equals": [
                                    "code"
                                ]
                            }
                        ]
                    },
                    "fields": [
                        {
                            "type": "boolean",
                            "name": "showEditor",
                            "label": "Show Editor?",
                            "description": "Should an editor displayed to the user",
                            "default": true
                        },
                        {
                            "name": "enableImageUploads",
                            "type": "boolean",
                            "label": "Enable image uploads",
                            "description": "If enabled for this content item, learners can upload images during runtime and access them in their code.",
                            "default": false
                        },
                        {
                            "name": "defaultImages",
                            "type": "list",
                            "label": "Default Images",
                            "entity": "image",
                            "optional": true,
                            "description": "Images that are preloaded into the Images tab for this content item.",
                            "field": {
                                "name": "defaultImage",
                                "type": "group",
                                "label": "Default Image",
                                "fields": [
                                    {
                                        "name": "image",
                                        "type": "image",
                                        "label": "Image"
                                    },
                                    {
                                        "name": "fileName",
                                        "type": "text",
                                        "label": "File Name",
                                        "optional": true,
                                        "description": "Optional file name shown in the Images tab (for example background.png)."
                                    }
                                ]
                            }
                        },
                        {
                            "name": "enableSoundUploads",
                            "type": "boolean",
                            "label": "Enable sound uploads",
                            "description": "If enabled for this content item, learners can upload sounds during runtime and access them in their code.",
                            "default": false
                        },
                        {
                            "name": "sourceFiles",
                            "type": "list",
                            "label": "Additional Python Files",
                            "entity": "file",
                            "optional": true,
                            "description": "Additional Python modules available for import in this editor when using Pyodide. Use module file names like helper.py.",
                            "field": {
                                "name": "sourceFile",
                                "type": "group",
                                "label": "Python File",
                                "fields": [
                                    {
                                        "name": "fileName",
                                        "type": "text",
                                        "label": "File Name",
                                        "description": "Python module file name, for example helper.py"
                                    },
                                    {
                                        "name": "code",
                                        "type": "text",
                                        "label": "Code",
                                        "widget": "codeWidget",
                                        "options": [
                                            {
                                                "language": "python"
                                            }
                                        ]
                                    },
                                    {
                                        "name": "visibleToLearner",
                                        "type": "boolean",
                                        "label": "Show file in editor",
                                        "description": "If enabled, learners can switch to this file in the editor.",
                                        "default": true
                                    },
                                    {
                                        "name": "learnerEditable",
                                        "type": "boolean",
                                        "label": "Learner can edit file",
                                        "description": "If enabled, learners can modify this file in the editor.",
                                        "default": true
                                    }
                                ]
                            }
                        },
                        {
                            "name": "allowAddingFiles",
                            "type": "boolean",
                            "label": "Allow learners to add files",
                            "description": "If enabled, learners can add, rename and delete their own Python files in this editor. Only applies when using Pyodide.",
                            "default": false
                        },
                        {
                            "name": "editorMode",
                            "type": "select",
                            "label": "Editor mode",
                            "description": "Choose whether learners see a code editor, a block-based editor, both panels with a toggle, or a fill-in-the-code template. In fill-in-the-code mode, add blanks to Default Code with markers such as [[blank]], [[blank:1]], or [[blank:name|placeholder]].",
                            "default": "code",
                            "options": [
                                {
                                    "value": "code",
                                    "label": "Code editor (CodeMirror)"
                                },
                                {
                                    "value": "blocks",
                                    "label": "Block editor (Blockly)"
                                },
                                {
                                    "value": "both",
                                    "label": "Both – blocks are source of truth, code preview is read-only"
                                },
                                {
                                    "value": "fill-blanks",
                                    "label": "Fill in code blanks"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "blocklyCategories",
                    "type": "group",
                    "label": "Blockly categories",
                    "description": "Select which block categories are available in the Blockly editor. All categories are included by default.",
                    "widget": "pythonQuestionShowWhen",
                    "showWhen": {
                        "rules": [
                            {
                                "field": "options/editorMode",
                                "equals": [
                                    "blocks",
                                    "both"
                                ]
                            }
                        ]
                    },
                    "fields": [
                        {
                            "name": "variables",
                            "type": "boolean",
                            "label": "Variables",
                            "default": true
                        },
                        {
                            "name": "logic",
                            "type": "boolean",
                            "label": "Logic",
                            "default": true
                        },
                        {
                            "name": "loops",
                            "type": "boolean",
                            "label": "Loops",
                            "default": true
                        },
                        {
                            "name": "math",
                            "type": "boolean",
                            "label": "Maths",
                            "default": true
                        },
                        {
                            "name": "text",
                            "type": "boolean",
                            "label": "Text",
                            "default": true
                        },
                        {
                            "name": "lists",
                            "type": "boolean",
                            "label": "Lists",
                            "default": true
                        },
                        {
                            "name": "functions",
                            "type": "boolean",
                            "label": "Functions",
                            "default": true
                        }
                    ]
                }
            ]
        }
    },
