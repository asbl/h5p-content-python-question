    {
        "name": "gradingSettings",
        "type": "group",
        "label": "Grading Settings",
        "widget": "pythonQuestionShowWhen",
        "showWhen": {
            "rules": [
                {
                    "field": "contentType",
                    "equals": [
                        "ide_only",
                        "text_and_ide"
                    ]
                }
            ]
        },
        "description": "Information how the content should be graded",
        "expanded": true,
        "fields": [
            {
                "name": "gradingMethod",
                "type": "select",
                "label": "Grading method",
                "description": "Grading methods",
                "default": "please_choose",
                "options": [
                    {
                        "value": "please_choose",
                        "label": "Please choose"
                    },
                    {
                        "value": "ioTestCases",
                        "label": "Input/Output TestCases"
                    },
                    {
                        "value": "targetImage",
                        "label": "Target Image"
                    },
                    {
                        "value": "functionTests",
                        "label": "Function Test Cases"
                    }
                    
                ]
            },
            {
                "name": "algorithmTrace",
                "type": "group",
                "label": "Algorithm trace (Pyodide only)",
                "description": "Shows explicit trace events for a visible function test case.",
                "widget": "showWhen",
                "showWhen": { "rules": [{ "field": "../pythonRunner", "equals": "pyodide" }, { "field": "gradingMethod", "equals": "functionTests" }] },
                "fields": [
                    { "name": "enabled", "type": "boolean", "label": "Enable array trace", "default": false },
                    { "name": "traceType", "type": "select", "label": "Trace type", "default": "array", "options": [{ "value": "array", "label": "Array" }] },
                    { "name": "traceTestCaseIndex", "type": "number", "label": "Visible test case index", "description": "Only this non-hidden test case is traced. The first test case has index 0.", "default": 0, "min": 0 },
                    { "name": "maxEvents", "type": "number", "label": "Maximum trace events", "description": "Stops recording after this many events.", "default": 500, "min": 1 },
                    { "name": "maxSnapshotLength", "type": "number", "label": "Maximum displayed array values", "description": "Longer arrays are truncated in the trace.", "default": 100, "min": 1 }
                ]
            },
            {
                "name": "algorithmConstraints",
                "type": "group",
                "label": "Algorithm constraints (Pyodide only)",
                "description": "Static AST checks for function tasks. These checks are only run with Pyodide.",
                "widget": "showWhen",
                "showWhen": { "rules": [{ "field": "../pythonRunner", "equals": "pyodide" }, { "field": "gradingMethod", "equals": "functionTests" }] },
                "fields": [
                    { "name": "requireRecursion", "type": "boolean", "label": "Require recursion", "default": false },
                    { "name": "requireBaseCase", "type": "boolean", "label": "Require recursion base case", "default": false },
                    { "name": "maxRecursiveCalls", "type": "number", "label": "Maximum recursive calls in source", "description": "0 means no limit.", "default": 0, "min": 0 },
                    { "name": "requiredLoop", "type": "select", "label": "Required loop", "default": "none", "options": [{ "value": "none", "label": "No requirement" }, { "value": "any", "label": "Any loop" }, { "value": "for", "label": "For loop" }, { "value": "while", "label": "While loop" }] },
                    { "name": "maxLoopCount", "type": "number", "label": "Maximum loops in source", "description": "0 means no limit.", "default": 0, "min": 0 },
                    { "name": "maxLoopNesting", "type": "number", "label": "Maximum loop nesting", "description": "0 means no limit.", "default": 0, "min": 0 },
                    { "name": "requireConditional", "type": "boolean", "label": "Require conditional", "default": false },
                    { "name": "requireReturn", "type": "boolean", "label": "Require return statement", "default": false },
                    { "name": "forbidTopLevelAssignments", "type": "boolean", "label": "Forbid top-level assignments", "default": false },
                    { "name": "forbiddenCalls", "type": "text", "label": "Forbidden function calls", "description": "Comma-separated function names or methods, for example sorted, sort, sum.", "optional": true },
                    { "name": "requiredDataStructures", "type": "list", "label": "Required data structures", "entity": "data structure", "optional": true, "field": { "name": "structure", "type": "select", "label": "Data structure", "options": [{ "value": "list", "label": "List" }, { "value": "dict", "label": "Dictionary" }, { "value": "set", "label": "Set" }, { "value": "tuple", "label": "Tuple" }] } },
                    { "name": "forbiddenDataStructures", "type": "list", "label": "Forbidden data structures", "entity": "data structure", "optional": true, "field": { "name": "structure", "type": "select", "label": "Data structure", "options": [{ "value": "list", "label": "List" }, { "value": "dict", "label": "Dictionary" }, { "value": "set", "label": "Set" }, { "value": "tuple", "label": "Tuple" }] } }
                ]
            },
